generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

// ─── Finance ────────────────────────────────────────────

model FixedExpense {
  id         String   @id @default(cuid())
  title      String
  value      Decimal  @db.Decimal(10, 2)
  category   String?
  bank       Bank     @default(NUBANK)
  validFrom  String   // formato: "YYYY-MM"
  deletedAt  String?  // formato: "YYYY-MM" — mês a partir do qual foi excluído
  createdAt  DateTime @default(now())
}

model Installment {
  id                  String   @id @default(cuid())
  title               String
  value               Decimal  @db.Decimal(10, 2)
  category            String?
  bank                Bank     @default(NUBANK)
  currentInstallment  Int
  totalInstallments   Int
  startMonth          String   // formato: "YYYY-MM"
  createdAt           DateTime @default(now())
}

model MonthlyBudget {
  id            String   @id @default(cuid())
  month         String   @unique
  incomeTotal   Decimal  @db.Decimal(10, 2)
  reserveAmount Decimal  @db.Decimal(10, 2) @default(0)
  carryOver2    Boolean  @default(false)
  carryOver3    Boolean  @default(false)
  carryOver4    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WeeklyExpense {
  id        String      @id @default(cuid())
  month     String      // formato: "YYYY-MM"
  week      Int         // 1, 2, 3 ou 4
  date      DateTime?
  title     String
  value     Decimal     @db.Decimal(10, 2)
  category  String?
  type      ExpenseType
  bank      Bank?
  createdAt DateTime    @default(now())
}

enum Bank {
  NUBANK
  MERCADO_PAGO
}

enum ExpenseType {
  CREDITO
  PIX
  RESERVADO
}